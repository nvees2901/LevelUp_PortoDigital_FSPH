# ====================================================================
# FSPH Backend — Variáveis de Ambiente
# ====================================================================
# ATENÇÃO: Copie este arquivo para .env e preencha os valores reais.
# O arquivo .env NUNCA deve ser versionado no Git.
# ====================================================================

# --------------------------------------------------------------------
# Banco de dados (PostgreSQL)
# --------------------------------------------------------------------
# Formato: postgresql+asyncpg://USUARIO:SENHA@HOST:PORTA/BANCO
# "asyncpg" é o driver assíncrono — necessário para FastAPI async
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/fsph

# --------------------------------------------------------------------
# Inteligência Artificial — Ollama (local, mais rápido)
# --------------------------------------------------------------------
# Ollama roda modelos localmente com resposta streaming rápida.
# Instale: https://ollama.com  |  Rode: ollama pull llama3.2
# Prioridade: Ollama > OpenRouter > OpenAI. Deixe VAZIO para pular.
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# --------------------------------------------------------------------
# Inteligência Artificial — OpenRouter (fallback remoto)
# --------------------------------------------------------------------
# OpenRouter usa modelos open-source gratuitos (Llama 3.3 70B).
# Obtenha sua chave em: https://openrouter.ai/keys
# Deixe VAZIO para modo MOCK (sem custo, ideal para desenvolvimento).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --------------------------------------------------------------------
# Inteligência Artificial — OpenAI (fallback)
# --------------------------------------------------------------------
# Usado apenas se OPENROUTER_API_KEY estiver vazio.
# Deixe ambos vazios para modo MOCK.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --------------------------------------------------------------------
# RAG / Banco Vetorial (ChromaDB server via Docker)
# --------------------------------------------------------------------
# RAG_ENABLED: conecta ao ChromaDB server para busca semântica.
# Requer: docker compose up chromadb
RAG_ENABLED=false
# CHROMA_HOST/PORT: endereço do ChromaDB server.
# Local (via docker compose): localhost:8100
# Dentro do Docker: chromadb:8000
CHROMA_HOST=localhost
CHROMA_PORT=8100
# DOCS_PATH: caminho para a pasta com a Lei 14.133 e TRs de referência.
DOCS_PATH=../docs

# --------------------------------------------------------------------
# Segurança
# --------------------------------------------------------------------
# Gere uma chave segura com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# --------------------------------------------------------------------
# Aplicação
# --------------------------------------------------------------------
DEBUG=true
ENVIRONMENT=development

# --------------------------------------------------------------------
# CORS — Origins permitidas (separadas por vírgula no .env)
# Defina no código como lista; aqui é apenas referência visual
# --------------------------------------------------------------------
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --------------------------------------------------------------------
# Upload de arquivos
# --------------------------------------------------------------------
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads

# --------------------------------------------------------------------
# Documentos de contexto da IA (gerenciados pelo administrador)
# --------------------------------------------------------------------
CONTEXT_DOCS_DIR=./context_documents
CONTEXT_DOC_MAX_SIZE_MB=20
