# ====================================================================
# FSPH Backend — Variáveis de Ambiente
# ====================================================================
# ATENÇÃO: Copie este arquivo para .env e preencha os valores reais.
# O arquivo .env NUNCA deve ser versionado no Git.
# ====================================================================

# --------------------------------------------------------------------
# Banco de dados (PostgreSQL)
# --------------------------------------------------------------------
# Formato: postgresql+asyncpg://USUARIO:SENHA@HOST:PORTA/BANCO
# "asyncpg" é o driver assíncrono — necessário para FastAPI async
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fsph

# --------------------------------------------------------------------
# Cache (Redis)
# --------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# --------------------------------------------------------------------
# Inteligência Artificial
# --------------------------------------------------------------------
# Deixe OPENAI_API_KEY vazio para usar o modo MOCK (sem custo).
# O sistema funciona completamente sem chave — ideal para desenvolvimento.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --------------------------------------------------------------------
# Segurança
# --------------------------------------------------------------------
# Gere uma chave segura com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# --------------------------------------------------------------------
# Aplicação
# --------------------------------------------------------------------
DEBUG=true
ENVIRONMENT=development

# --------------------------------------------------------------------
# CORS — Origins permitidas (separadas por vírgula no .env)
# Defina no código como lista; aqui é apenas referência visual
# --------------------------------------------------------------------
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --------------------------------------------------------------------
# Upload de arquivos
# --------------------------------------------------------------------
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads
